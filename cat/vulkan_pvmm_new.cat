let avsg2 = avsgl2 | ([SC2]; po; [SG & SEMSC2 & SEMAV])
let avwg2 = avwgl2 | ([SC2]; po; [WG & SEMSC2 & SEMAV]) | ((chains & (avsg2; (ssg & ithb2))); [WG & SEMSC2 & SEMAV])
let avqf2 = avqfl2 | ([SC2]; po; [QF & SEMSC2 & SEMAV]) | ((chains & ((avsg2; (ssg & ithb2)) | (avwg2; (swg & ithb2)))); [QF & SEMSC2 & SEMAV])
let avdv2 = avdvl2 | ([SC2]; po; [DV & SEMSC2 & SEMAV]) | ((chains & ((avsg2; (ssg & ithb2)) | (avwg2; (swg & ithb2)) | (avqf2; (sqf & ithb2)))); [DV & SEMSC2 & SEMAV])

let vissgl2 = [SG & SC2]; (po & vloc & loc)?; [SC2]
let viswgl2 = ([WG & SC2]; (po & vloc & loc)?; [SC2]) | ([WG & SC2]; (ssg & ithb2 & vloc & loc)?; vissgl2)
let visqfl2 = ([QF & SC2]; (po & vloc & loc)?; [SC2]) | ([QF & SC2]; (ssg & ithb2 & vloc & loc)?; vissgl2) | ([QF & SC2]; (swg & ithb2 & vloc & loc)?; viswgl2)
let visdvl2 = ([DV & SC2]; (po & vloc & loc)?; [SC2]) | ([DV & SC2]; (ssg & ithb2 & vloc & loc)?; vissgl2) | ([DV & SC2]; (swg & ithb2 & vloc & loc)?; viswgl2) | ([DV & SC2]; (sqf & ithb2 & vloc & loc)?; visqfl2)

let vissg2 = vissgl2 | ([SG & SEMSC2 & SEMVIS]; po; [SC2])
let viswg2 = viswgl2 | ([WG & SEMSC2 & SEMVIS]; po; [SC2]) | ([WG & SEMSC2 & SEMVIS]; (chains & ((ssg & ithb2); vissg2)))
let visqf2 = visqfl2 | ([QF & SEMSC2 & SEMVIS]; po; [SC2]) | ([QF & SEMSC2 & SEMVIS]; (chains & (((swg & ithb2); viswg2) | ((ssg & ithb2); vissg2))))
let visdv2 = visdvl2 | ([DV & SEMSC2 & SEMVIS]; po; [SC2]) | ([DV & SEMSC2 & SEMVIS]; (chains & (((sqf & ithb2); visqf2) | ((swg & ithb2); viswg2) | ((ssg & ithb2); vissg2))))

// ==========================================
// LEVEL 3: SC3, SEMSC3, ithb3
// ==========================================
let avsgl3 = [SC3]; (po & vloc & loc)?; [SG & SC3]
let avwgl3 = ([SC3]; (po & vloc & loc)?; [WG & SC3]) | (avsgl3; (ssg & ithb3 & vloc & loc); [WG & SC3])
let avqfl3 = ([SC3]; (po & vloc & loc)?; [QF & SC3]) | (avsgl3; (ssg & ithb3 & vloc & loc); [QF & SC3]) | (avwgl3; (swg & ithb3 & vloc & loc)?; [QF & SC3])
let avdvl3 = ([SC3]; (po & vloc & loc)?; [DV & SC3]) | (avsgl3; (ssg & ithb3 & vloc & loc); [DV & SC3]) | (avwgl3; (swg & ithb3 & vloc & loc)?; [DV & SC3]) | (avqfl3; (sqf & ithb3 & vloc & loc)?; [DV & SC3])

let avsg3 = avsgl3 | ([SC3]; po; [SG & SEMSC3 & SEMAV])
let avwg3 = avwgl3 | ([SC3]; po; [WG & SEMSC3 & SEMAV]) | ((chains & (avsg3; (ssg & ithb3))); [WG & SEMSC3 & SEMAV])
let avqf3 = avqfl3 | ([SC3]; po; [QF & SEMSC3 & SEMAV]) | ((chains & ((avsg3; (ssg & ithb3)) | (avwg3; (swg & ithb3)))); [QF & SEMSC3 & SEMAV])
let avdv3 = avdvl3 | ([SC3]; po; [DV & SEMSC3 & SEMAV]) | ((chains & ((avsg3; (ssg & ithb3)) | (avwg3; (swg & ithb3)) | (avqf3; (sqf & ithb3)))); [DV & SEMSC3 & SEMAV])

let vissgl3 = [SG & SC3]; (po & vloc & loc)?; [SC3]
let viswgl3 = ([WG & SC3]; (po & vloc & loc)?; [SC3]) | ([WG & SC3]; (ssg & ithb3 & vloc & loc)?; vissgl3)
let visqfl3 = ([QF & SC3]; (po & vloc & loc)?; [SC3]) | ([QF & SC3]; (ssg & ithb3 & vloc & loc)?; vissgl3) | ([QF & SC3]; (swg & ithb3 & vloc & loc)?; viswgl3)
let visdvl3 = ([DV & SC3]; (po & vloc & loc)?; [SC3]) | ([DV & SC3]; (ssg & ithb3 & vloc & loc)?; vissgl3) | ([DV & SC3]; (swg & ithb3 & vloc & loc)?; viswgl3) | ([DV & SC3]; (sqf & ithb3 & vloc & loc)?; visqfl3)

let vissg3 = vissgl3 | ([SG & SEMSC3 & SEMVIS]; po; [SC3])
let viswg3 = viswgl3 | ([WG & SEMSC3 & SEMVIS]; po; [SC3]) | ([WG & SEMSC3 & SEMVIS]; (chains & ((ssg & ithb3); vissg3)))
let visqf3 = visqfl3 | ([QF & SEMSC3 & SEMVIS]; po; [SC3]) | ([QF & SEMSC3 & SEMVIS]; (chains & (((swg & ithb3); viswg3) | ((ssg & ithb3); vissg3))))
let visdv3 = visdvl3 | ([DV & SEMSC3 & SEMVIS]; po; [SC3]) | ([DV & SEMSC3 & SEMVIS]; (chains & (((sqf & ithb3); visqf3) | ((swg & ithb3); viswg3) | ((ssg & ithb3); vissg3))))

let locordww = (avsg0; (ithb0 & ssg)) | (avwg0; (ithb0 & swg)) | (avqf0; (ithb0 & sqf)) | (avdv0; ithb0) |
               (avsg1; (ithb1 & ssg)) | (avwg1; (ithb1 & swg)) | (avqf1; (ithb1 & sqf)) | (avdv1; ithb1) |
               (avsg2; (ithb2 & ssg)) | (avwg2; (ithb2 & swg)) | (avqf2; (ithb2 & sqf)) | (avdv2; ithb2) |
               (avsg3; (ithb3 & ssg)) | (avwg3; (ithb3 & swg)) | (avqf3; (ithb3 & sqf)) | (avdv3; ithb3)

let locordrr = (avsg0; (ithb0 & ssg); vissg0) | (avwg0; (ithb0 & swg); viswg0) | (avqf0; (ithb0 & sqf); visqf0) | (avdv0; ithb0; visdv0) |
               (avsg1; (ithb1 & ssg); vissg1) | (avwg1; (ithb1 & swg); viswg1) | (avqf1; (ithb1 & sqf); visqf1) | (avdv1; ithb1; visdv1) |
               (avsg2; (ithb2 & ssg); vissg2) | (avwg2; (ithb2 & swg); viswg2) | (avqf2; (ithb2 & sqf); visqf2) | (avdv2; ithb2; visdv2) |
               (avsg3; (ithb3 & ssg); vissg3) | (avwg3; (ithb3 & swg); viswg3) | (avqf3; (ithb3 & sqf); visqf3) | (avdv3; ithb3; visdv3)

let shb = ((SC0 * SC0) & ithb0) | ((SC1 * SC1) & ithb1) |
          ((SC2 * SC2) & ithb2) | ((SC3 * SC3) & ithb3) |
          (((SC0 * SC1) | (SC1 * SC0)) & ithb01) |
          (((SC0 * SC2) | (SC2 * SC0)) & ithb02) |
          (((SC0 * SC3) | (SC3 * SC0)) & ithb03) |
          (((SC1 * SC2) | (SC2 * SC1)) & ithb12) |
          (((SC1 * SC3) | (SC3 * SC1)) & ithb13) |
          (((SC2 * SC3) | (SC3 * SC2)) & ithb23)

let locord = loc & (
    (IW * (W \ IW)) |
    ([R]; ssw+; [R | W]) |
    // TODO: Should also be matching hb
    ([W]; hb; [AVDEVICE]; hb; [W]) |
    ([W]; hb; [AVDEVICE]; hb; [VISDEVICE]; hb; [R]) |
    ([R & NONPRIV]; (po | shb); [(R | W) & NONPRIV]) |
    vloc & (
        ((po | shb) & int) |
        ([W & NONPRIV]; locordww; [W & NONPRIV]) |
        ([W & NONPRIV]; locordrr; [R & NONPRIV])
    )
)

// From-read is defined based on scoped modification order
// instead of coherence. For reads that read-from init, they
// from-read all writes at the same location.

// The definition of the original Vulkan model is too restrictive and forbids CoWW-RR
// let fr = (rf^-1 ; ((W * W) & locord)) | (rf^-1; asmo) | (([IW]; rf)^-1; ((loc;[W]) \ id))
let fr = ((rf & locord)^-1 ; (W * W) & locord) | (rf^-1; asmo) | (([IW]; rf)^-1; ((loc;[W]) \ id))
let fre = fr & ext

(***********************)
(* Memory Model Axioms *)
(***********************)

// locord, rf, fr, asmo must not form cycles
acyclic (locord | rf | fr | asmo) as consistency-cycle

// non-atomic cannot read-from a value that is shadowed by another write
// empty rf & (([W]; locord; [W]); locord+) as consistency-rf
empty (rf; ([R \ ATOM])) & (([W]; locord); ([W]; locord)+) as consistency-rf

// rmw events are atomic
empty rmw & (fre; (asmo & ext)) as atomic

(***************)
(* Data Races *)
(***************)

let pair_with_write = ((W * W) | (W * R) | (R * W)) \ ((IW * _) | (_ * IW)) // ignore IW
let dr = loc & (pair_with_write \ mutordatom \ id \ (locord | locord^-1))
flag ~empty dr as racy