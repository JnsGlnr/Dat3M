// ==========================================
// LEVEL 0: SC0, SEMSC0, ithb0
// ==========================================
let avsgl0 = [SC0]; (po & vloc & loc)?; [SG & SC0]
let avwgl0 = ([SC0]; (po & vloc & loc)?; [WG & SC0]) | (avsgl0; (ssg & ithb0 & vloc & loc); [WG & SC0])
let avqfl0 = ([SC0]; (po & vloc & loc)?; [QF & SC0]) | (avsgl0; (ssg & ithb0 & vloc & loc); [QF & SC0]) | (avwgl0; (swg & ithb0 & vloc & loc)?; [QF & SC0])
let avdvl0 = ([SC0]; (po & vloc & loc)?; [DV & SC0]) | (avsgl0; (ssg & ithb0 & vloc & loc); [DV & SC0]) | (avwgl0; (swg & ithb0 & vloc & loc)?; [DV & SC0]) | (avqfl0; (sqf & ithb0 & vloc & loc)?; [DV & SC0])

let avsg0 = avsgl0 | ([SC0]; po; [SG & SEMSC0 & SEMAV])
let avwg0 = avwgl0 | ([SC0]; po; [WG & SEMSC0 & SEMAV]) | ((chains & (avsg0; (ssg & ithb0))); [WG & SEMSC0 & SEMAV])
let avqf0 = avqfl0 | ([SC0]; po; [QF & SEMSC0 & SEMAV]) | ((chains & ((avsg0; (ssg & ithb0)) | (avwg0; (swg & ithb0)))); [QF & SEMSC0 & SEMAV])
let avdv0 = avdvl0 | ([SC0]; po; [DV & SEMSC0 & SEMAV]) | ((chains & ((avsg0; (ssg & ithb0)) | (avwg0; (swg & ithb0)) | (avqf0; (sqf & ithb0)))); [DV & SEMSC0 & SEMAV])

let vissgl0 = [SG & SC0]; (po & vloc & loc)?; [SC0]
let viswgl0 = ([WG & SC0]; (po & vloc & loc)?; [SC0]) | ([WG & SC0]; (ssg & ithb0 & vloc & loc)?; vissgl0)
let visqfl0 = ([QF & SC0]; (po & vloc & loc)?; [SC0]) | ([QF & SC0]; (ssg & ithb0 & vloc & loc)?; vissgl0) | ([QF & SC0]; (swg & ithb0 & vloc & loc)?; viswgl0)
let visdvl0 = ([DV & SC0]; (po & vloc & loc)?; [SC0]) | ([DV & SC0]; (ssg & ithb0 & vloc & loc)?; vissgl0) | ([DV & SC0]; (swg & ithb0 & vloc & loc)?; viswgl0) | ([DV & SC0]; (sqf & ithb0 & vloc & loc)?; visqfl0)

let vissg0 = vissgl0 | ([SG & SEMSC0 & SEMVIS]; po; [SC0])
let viswg0 = viswgl0 | ([WG & SEMSC0 & SEMVIS]; po; [SC0]) | ([WG & SEMSC0 & SEMVIS]; (chains & ((ssg & ithb0); vissg0)))
let visqf0 = visqfl0 | ([QF & SEMSC0 & SEMVIS]; po; [SC0]) | ([QF & SEMSC0 & SEMVIS]; (chains & (((swg & ithb0); viswg0) | ((ssg & ithb0); vissg0))))
let visdv0 = visdvl0 | ([DV & SEMSC0 & SEMVIS]; po; [SC0]) | ([DV & SEMSC0 & SEMVIS]; (chains & (((sqf & ithb0); visqf0) | ((swg & ithb0); viswg0) | ((ssg & ithb0); vissg0))))

// ==========================================
// LEVEL 1: SC1, SEMSC1, ithb1
// ==========================================
let avsgl1 = [SC1]; (po & vloc & loc)?; [SG & SC1]
let avwgl1 = ([SC1]; (po & vloc & loc)?; [WG & SC1]) | (avsgl1; (ssg & ithb1 & vloc & loc); [WG & SC1])
let avqfl1 = ([SC1]; (po & vloc & loc)?; [QF & SC1]) | (avsgl1; (ssg & ithb1 & vloc & loc); [QF & SC1]) | (avwgl1; (swg & ithb1 & vloc & loc)?; [QF & SC1])
let avdvl1 = ([SC1]; (po & vloc & loc)?; [DV & SC1]) | (avsgl1; (ssg & ithb1 & vloc & loc); [DV & SC1]) | (avwgl1; (swg & ithb1 & vloc & loc)?; [DV & SC1]) | (avqfl1; (sqf & ithb1 & vloc & loc)?; [DV & SC1])

let avsg1 = avsgl1 | ([SC1]; po; [SG & SEMSC1 & SEMAV])
let avwg1 = avwgl1 | ([SC1]; po; [WG & SEMSC1 & SEMAV]) | ((chains & (avsg1; (ssg & ithb1))); [WG & SEMSC1 & SEMAV])
let avqf1 = avqfl1 | ([SC1]; po; [QF & SEMSC1 & SEMAV]) | ((chains & ((avsg1; (ssg & ithb1)) | (avwg1; (swg & ithb1)))); [QF & SEMSC1 & SEMAV])
let avdv1 = avdvl1 | ([SC1]; po; [DV & SEMSC1 & SEMAV]) | ((chains & ((avsg1; (ssg & ithb1)) | (avwg1; (swg & ithb1)) | (avqf1; (sqf & ithb1)))); [DV & SEMSC1 & SEMAV])

let vissgl1 = [SG & SC1]; (po & vloc & loc)?; [SC1]
let viswgl1 = ([WG & SC1]; (po & vloc & loc)?; [SC1]) | ([WG & SC1]; (ssg & ithb1 & vloc & loc)?; vissgl1)
let visqfl1 = ([QF & SC1]; (po & vloc & loc)?; [SC1]) | ([QF & SC1]; (ssg & ithb1 & vloc & loc)?; vissgl1) | ([QF & SC1]; (swg & ithb1 & vloc & loc)?; viswgl1)
let visdvl1 = ([DV & SC1]; (po & vloc & loc)?; [SC1]) | ([DV & SC1]; (ssg & ithb1 & vloc & loc)?; vissgl1) | ([DV & SC1]; (swg & ithb1 & vloc & loc)?; viswgl1) | ([DV & SC1]; (sqf & ithb1 & vloc & loc)?; visqfl1)

let vissg1 = vissgl1 | ([SG & SEMSC1 & SEMVIS]; po; [SC1])
let viswg1 = viswgl1 | ([WG & SEMSC1 & SEMVIS]; po; [SC1]) | ([WG & SEMSC1 & SEMVIS]; (chains & ((ssg & ithb1); vissg1)))
let visqf1 = visqfl1 | ([QF & SEMSC1 & SEMVIS]; po; [SC1]) | ([QF & SEMSC1 & SEMVIS]; (chains & (((swg & ithb1); viswg1) | ((ssg & ithb1); vissg1))))
let visdv1 = visdvl1 | ([DV & SEMSC1 & SEMVIS]; po; [SC1]) | ([DV & SEMSC1 & SEMVIS]; (chains & (((sqf & ithb1); visqf1) | ((swg & ithb1); viswg1) | ((ssg & ithb1); vissg1))))

// ==========================================
// LEVEL 2: SC2, SEMSC2, ithb2
// ==========================================
let avsgl2 = [SC2]; (po & vloc & loc)?; [SG & SC2]
let avwgl2 = ([SC2]; (po & vloc & loc)?; [WG & SC2]) | (avsgl2; (ssg & ithb2 & vloc & loc); [WG & SC2])
let avqfl2 = ([SC2]; (po & vloc & loc)?; [QF & SC2]) | (avsgl2; (ssg & ithb2 & vloc & loc); [QF & SC2]) | (avwgl2; (swg & ithb2 & vloc & loc)?; [QF & SC2])
