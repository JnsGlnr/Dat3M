VULKAN
(* Vulkan Memory Model *)
(* With availability-visibility chains supported *)

// Base relations:
// vloc: events accessing the same virtual location, aka "same reference (sref)" in the Vulkan spec
// syncbar: synchronize by barriers with same logical barrier resource (barID)
// ssg: same subgroup
// swg: same workgroup
// sqf: same queuefamily
// ssw: system-synchronizes-with

// Tags:
// SC0, SC1, SC2, SC3: storage class 0, 1, 2, 3
// SEMSC0, SEMSC1, SEMSC2, SEMSC3: storage class semantics 0, 1, 2, 3
// SG, WG, QF, DV: subgroup, workgroup, queuefamily, device domains
// AV, VIS: availability, visibility
// AVDEVICE, VISDEVICE: availability, visibility op to the device domain

(*******************)
(*  Auxiliaries *)
(*******************)

(* Tags *)
let QF = QF | DV
let WG = WG | QF
let SG = SG | WG

let SC01 = SC0 | SC1
let SC02 = SC0 | SC2
let SC03 = SC0 | SC3
let SC12 = SC1 | SC2
let SC13 = SC1 | SC3
let SC23 = SC2 | SC3
let SC012 = SC01 | SC2
let SC013 = SC01 | SC3
let SC023 = SC02 | SC3
let SC123 = SC12 | SC3
let SC0123 = SC012 | SC3

let SEMSC01 = SEMSC0 & SEMSC1
let SEMSC02 = SEMSC0 & SEMSC2
let SEMSC03 = SEMSC0 & SEMSC3
let SEMSC12 = SEMSC1 & SEMSC2
let SEMSC13 = SEMSC1 & SEMSC3
let SEMSC23 = SEMSC2 & SEMSC3
let SEMSC012 = SEMSC01 & SEMSC2
let SEMSC013 = SEMSC01 & SEMSC3
let SEMSC023 = SEMSC02 & SEMSC3
let SEMSC123 = SEMSC12 & SEMSC3
let SEMSC0123 = SEMSC012 & SEMSC3

(* Relations *)
let inscope = (DV * DV) | (sqf & (QF * QF)) | (swg & (WG * WG)) | (ssg & (SG * SG))
let mutordatom = (loc & vloc & inscope & (ATOM * ATOM)) \ id
let asmo = co & mutordatom

let sc2sem = (SC0 * SEMSC0) | (SC1 * SEMSC1) | (SC2 * SEMSC2) | (SC3 * SEMSC3)
let sem2sc = (SEMSC0 * SC0) | (SEMSC1 * SC1) | (SEMSC2 * SC2) | (SEMSC3 * SC3)

let posctosem = po & sc2sem
let posemtosc = po & sem2sc

let imm(r) = r \ (r; r+)
let rs = [REL & ATOM]; (imm(asmo); [RMW])*
let hypors = [W & ATOM]; (imm(asmo); [RMW])*

// synchronizes-with is similar to C++, with an additional case for fence->cbar->cbar->fence
let sw = inscope & (
    ([REL & ATOM]; rs; (rf & mutordatom); [ACQ & ATOM]) |                                               // atomic->atomic
    ([REL & F]; posemtosc; [ATOM & W]; hypors; (rf & mutordatom); [ACQ & ATOM]) |                       // fence->atomic
    ([REL & ATOM]; rs; (rf & mutordatom); [ATOM & R]; posctosem; [ACQ & F]) |                           // atomic->fence
    ([REL & F]; posemtosc; [ATOM & W]; hypors; (rf & mutordatom); [ATOM & R]; posctosem; [ACQ & F]) |   // fence->fence
    // (stor[CBAR]) terms are redundant because scbarinst is an equivalence relation on scbarinst, but they make the sequence of instructions more clear.
    ([REL & F]; po?; [CBAR]; ((syncbar & inscope) \ id); [CBAR]; po?; [ACQ & F])                        // fence->cbar->cbar->fence,
)

let ithb(SC, SEMSC) = (ssw |
        ([SEMSC]; sw; [SEMSC]) |
        ([(NONPRIV & SC) | SEMSC]; po; [REL & SEMSC]) |
        ([ACQ & SEMSC]; po; [(NONPRIV & SC) | SEMSC])
    )+

let ithb0 = ithb(SC0, SEMSC0)
let ithb1 = ithb(SC1, SEMSC1)
let ithb2 = ithb(SC2, SEMSC2)
let ithb3 = ithb(SC3, SEMSC3)
let ithb01 = ithb(SC01, SEMSC01)
let ithb02 = ithb(SC02, SEMSC02)
let ithb03 = ithb(SC03, SEMSC03)
let ithb12 = ithb(SC12, SEMSC12)
let ithb13 = ithb(SC13, SEMSC13)
let ithb23 = ithb(SC23, SEMSC23)

let hb = po | ithb0 | ithb1 | ithb2 | ithb3 |
         ithb01 | ithb02 | ithb03 | ithb12 | ithb13 | ithb23

/*
let avsgl(SC) = [SC]; (po & vloc & loc)?; [SG & SC]
let avwgl(SC, ithb) = ([SC]; (po & vloc & loc)?; [WG & SC]) | (avsgl(SC); (ssg & ithb & vloc & loc); [WG & SC])
let avqfl(SC, ithb) = ([SC]; (po & vloc & loc)?; [QF & SC]) | (avsgl(SC); (ssg & ithb & vloc & loc); [QF & SC]) | (avwgl(SC, ithb); (swg & ithb & vloc & loc)?; [QF & SC])
let avdvl(SC, ithb) = ([SC]; (po & vloc & loc)?; [DV & SC]) | (avsgl(SC); (ssg & ithb & vloc & loc); [DV & SC]) | (avwgl(SC, ithb); (swg & ithb & vloc & loc)?; [DV & SC]) | (avqfl(SC, ithb); (sqf & ithb & vloc & loc)?; [DV & SC])

let avsg0 = avsgl(SC0) | ([SC0]; po; [SG & SEMSC0 & SEMAV])
let avwg0 = avwgl(SC0, ithb0) | ([SC0]; po; [WG & SEMSC0 & SEMAV]) | ((chains & (avsg0; (ssg & ithb0))); [WG & SEMSC0 & SEMAV])
let avqf0 = avqfl(SC0, ithb0) | ([SC0]; po; [QF & SEMSC0 & SEMAV]) | ((chains & (avsg0; (ssg & ithb0))); [QF & SEMSC0 & SEMAV]) | ((chains & (avwg0; (swg & ithb0))); [QF & SEMSC0 & SEMAV])
let avdv0 = avdvl(SC0, ithb0) | ([SC0]; po; [DV & SEMSC0 & SEMAV]) | ((chains & (avsg0; (ssg & ithb0))); [DV & SEMSC0 & SEMAV]) | ((chains & (avwg0; (swg & ithb0))); [DV & SEMSC0 & SEMAV]) | ((chains & (avqf0; (sqf & ithb0))); [DV & SEMSC0 & SEMAV])

let avsg1 = avsgl(SC1) | ([SC1]; po; [SG & SEMSC1 & SEMAV])
let avwg1 = avwgl(SC1, ithb1) | ([SC1]; po; [WG & SEMSC1 & SEMAV]) | ((chains & (avsg1; (ssg & ithb1))); [WG & SEMSC1 & SEMAV])
let avqf1 = avqfl(SC1, ithb1) | ([SC1]; po; [QF & SEMSC1 & SEMAV]) | ((chains & (avsg1; (ssg & ithb1))); [QF & SEMSC1 & SEMAV]) | ((chains & (avwg1; (swg & ithb1))); [QF & SEMSC1 & SEMAV])
let avdv1 = avdvl(SC1, ithb1) | ([SC1]; po; [DV & SEMSC1 & SEMAV]) | ((chains & (avsg1; (ssg & ithb1))); [DV & SEMSC1 & SEMAV]) | ((chains & (avwg1; (swg & ithb1))); [DV & SEMSC1 & SEMAV]) | ((chains & (avqf1; (sqf & ithb1))); [DV & SEMSC1 & SEMAV])

let avsg2 = avsgl(SC2) | ([SC2]; po; [SG & SEMSC2 & SEMAV])
let avwg2 = avwgl(SC2, ithb2) | ([SC2]; po; [WG & SEMSC2 & SEMAV]) | ((chains & (avsg2; (ssg & ithb2))); [WG & SEMSC2 & SEMAV])
let avqf2 = avqfl(SC2, ithb2) | ([SC2]; po; [QF & SEMSC2 & SEMAV]) | ((chains & (avsg2; (ssg & ithb2))); [QF & SEMSC2 & SEMAV]) | ((chains & (avwg2; (swg & ithb2))); [QF & SEMSC2 & SEMAV])
let avdv2 = avdvl(SC2, ithb2) | ([SC2]; po; [DV & SEMSC2 & SEMAV]) | ((chains & (avsg2; (ssg & ithb2))); [DV & SEMSC2 & SEMAV]) | ((chains & (avwg2; (swg & ithb2))); [DV & SEMSC2 & SEMAV]) | ((chains & (avqf2; (sqf & ithb2))); [DV & SEMSC2 & SEMAV])

let avsg3 = avsgl(SC3) | ([SC3]; po; [SG & SEMSC3 & SEMAV])
let avwg3 = avwgl(SC3, ithb3) | ([SC3]; po; [WG & SEMSC3 & SEMAV]) | ((chains & (avsg3; (ssg & ithb3))); [WG & SEMSC3 & SEMAV])
let avqf3 = avqfl(SC3, ithb3) | ([SC3]; po; [QF & SEMSC3 & SEMAV]) | ((chains & (avsg3; (ssg & ithb3))); [QF & SEMSC3 & SEMAV]) | ((chains & (avwg3; (swg & ithb3))); [QF & SEMSC3 & SEMAV])
let avdv3 = avdvl(SC3, ithb3) | ([SC3]; po; [DV & SEMSC3 & SEMAV]) | ((chains & (avsg3; (ssg & ithb3))); [DV & SEMSC3 & SEMAV]) | ((chains & (avwg3; (swg & ithb3))); [DV & SEMSC3 & SEMAV]) | ((chains & (avqf3; (sqf & ithb3))); [DV & SEMSC3 & SEMAV])

let vissgl(SC) = [SG & SC]; (po & vloc & loc)?; [SC]
let viswgl(SC, ithb) = ([WG & SC]; (po & vloc & loc)?; [SC]) | ([WG & SC]; (ssg & ithb & vloc & loc)?; vissgl(SC))
let visqfl(SC, ithb) = ([QF & SC]; (po & vloc & loc)?; [SC]) | ([QF & SC]; (ssg & ithb & vloc & loc)?; vissgl(SC)) | ([QF & SC]; (swg & ithb & vloc & loc)?; viswgl(SC, ithb))
let visdvl(SC, ithb) = ([DV & SC]; (po & vloc & loc)?; [SC]) | ([DV & SC]; (ssg & ithb & vloc & loc)?; vissgl(SC)) | ([DV & SC]; (swg & ithb & vloc & loc)?; viswgl(SC, ithb)) | ([DV & SC]; (sqf & ithb & vloc & loc)?; visqfl(SC, ithb))

let vissg0 = vissgl(SC0) | ([SG & SEMSC0 & SEMVIS]; po; [SC0])
let viswg0 = viswgl(SC0, ithb0) | ([WG & SEMSC0 & SEMVIS]; po; [SC0]) | ([WG & SEMSC0 & SEMVIS]; (chains & ((ssg & ithb0); vissg0)))
let visqf0 = visqfl(SC0, ithb0) | ([QF & SEMSC0 & SEMVIS]; po; [SC0]) | ([QF & SEMSC0 & SEMVIS]; (chains & ((swg & ithb0); viswg0))) | ([QF & SEMSC0 & SEMVIS]; (chains & ((ssg & ithb0); vissg0)))
