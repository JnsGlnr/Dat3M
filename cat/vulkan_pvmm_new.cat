let visdv1 = visdvl(SC1, ithb1) | ([DV & SEMSC1 & SEMVIS]; po; [SC1]) | ([DV & SEMSC1 & SEMVIS]; (chains & ((sqf & ithb1); visqf1))) | ([DV & SEMSC1 & SEMVIS]; (chains & ((swg & ithb1); viswg1))) | ([DV & SEMSC1 & SEMVIS]; (chains & ((ssg & ithb1); vissg1)))

