Vulkan
{}
 P0@sg 0, wg 0, qf 0            | P1@sg 1, wg 0, qf 0             | P2@sg 0, wg 1, qf 0             ;
 st.nonpriv.sc0 y, 1            | ld.atom.acq.wg.sc0.semsc0 r0, y | ld.atom.acq.qf.sc0.semsc0 r0, y ;
 st.atom.rel.wg.sc0.semsc0 y, 2 | st.atom.rel.qf.sc0.semsc0 y, 3  | ld.nonpriv.sc0 r1, y            ;
filter
(P1:r0 == 2 /\ P2:r0 == 3)
exists
(P1:r0 == 2 /\ P2:r0 == 3 /\ P2:r1 != 3)