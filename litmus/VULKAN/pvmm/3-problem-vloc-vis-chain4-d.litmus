 st.atom.rel.dv.sc0.semsc0 x, 2 | st.atom.rel.qf.sc0.semsc0 y, 1         | st.atom.rel.wg.sc0.semsc0 y, 2  | ld.nonpriv.sc0 r1, x            ;
