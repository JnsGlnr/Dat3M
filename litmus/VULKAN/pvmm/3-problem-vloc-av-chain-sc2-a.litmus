Vulkan
{}
 P0@sg 0, wg 0, qf 0                   | P1@sg 1, wg 0, qf 0                    | P2@sg 0, wg 1, qf 0                    ;
 st.nonpriv.sc0 x, 1                   | ld.atom.acq.wg.sc0.semsc0.semsc1 r0, x | ld.atom.acq.qf.sc1.semsc0.semsc1 r0, y ;
 st.atom.rel.wg.sc0.semsc0.semsc1 x, 2 | st.atom.rel.qf.sc1.semsc0.semsc1 y, 1  | ld.vis.qf.sc0 r1, x                    ;
filter
(P1:r0 == 2 /\ P2:r0 == 1)
exists
(P1:r0 == 2 /\ P2:r0 == 1 /\ P2:r1 != 2)