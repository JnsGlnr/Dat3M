{}
 P0@sg 0, wg 0, qf 0                   | P1@sg 0,wg 1, qf 0                     ;
 st.atom.rel.dv.sc0.semsc0.semsc1 x, 1 | ld.atom.acq.dv.sc1.semsc1 r0, y        ;
