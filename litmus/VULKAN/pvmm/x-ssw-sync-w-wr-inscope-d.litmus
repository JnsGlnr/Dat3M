VULKAN
{}
{
ssw 0 1;
ssw 1 2;
}
 P0@sg 0,wg 0, qf 0 | P1@sg 0,wg 0, qf 0 | P2@sg 0, wg 0, qf 1            | P3@sg 0, wg 1, qf 1             ;
 st.sc0 x, 1        | visdevice          | st.atom.qf.sc0 x, 2            | ld.atom.acq.qf.sc0.semsc0 r0, y ;
                    | avdevice           | st.atom.rel.qf.sc0.semsc0 y, 1 | ld.atom.qf.sc0 r1, x            ;
filter
(P3:r0 == 1)
exists
(P3:r0 == 1 /\ P3:r1 != 2)