Vulkan
{}
 P0@sg 0, wg 0, qf 0            | P1@sg 0, wg 1, qf 0                    | P2@sg 0, wg 2, qf 0                    | P3@sg 0, wg 2, qf 0                    ;
 st.av.qf.sc0 x, 1              | ld.atom.acq.qf.sc0.semsc0.semvis r0, a | ld.atom.acq.qf.sc0.semsc0.semvis r0, b | ld.atom.acq.sg.sc0.semsc0.semvis r0, c ;
 st.atom.rel.qf.sc0.semsc0 a, 1 | ld.nonpriv.sc0 r1, x                   | ld.nonpriv.sc0 r1, x                   | ld.nonpriv.sc0 r1, x                   ;
                                | st.atom.rel.qf.sc0.semsc0 b, 1         | st.atom.rel.sg.sc0.semsc0 c, 1         |                                        ;
filter
(P1:r0 == 1 /\ P2:r0 == 1 /\ P3:r0 == 1)
exists
(P1:r0 == 1 /\ P2:r0 == 1 /\ P3:r0 == 1 /\ (P1:r1 != 1 \/ P2:r1 != 1 \/ P3:r1 != 1))