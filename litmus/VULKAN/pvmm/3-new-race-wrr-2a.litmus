{}
 P0@sg 0, wg 0, qf 0            | P1@sg 1, wg 0, qf 0             | P2@sg 0, wg 1, qf 0             ;
 st.atom.rel.qf.sc0.semsc0 a, 1 | ld.atom.acq.wg.sc0.semsc0 r0, a | ld.atom.acq.qf.sc0.semsc0 r0, b ;
                                | st.atom.rel.qf.sc0.semsc0 b, 1  | ld.atom.acq.wg.sc0.semsc0 r1, a ;
